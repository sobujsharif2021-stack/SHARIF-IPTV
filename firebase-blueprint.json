{
  "entities": {
    "media": {
      "title": "Media Item",
      "description": "An individual media stream (movie, live tv, sports, cartoon).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "description": "sports | cartoon | news | movie" },
        "thumbnail": { "type": "string" },
        "streamUrl": { "type": "string" },
        "isLive": { "type": "boolean" }
      },
      "required": ["id", "title", "category", "streamUrl"]
    }
  },
  "firestore": {
    "/media/{mediaId}": {
      "schema": { "$ref": "media" },
      "description": "Stores all media items."
    }
  }
}
